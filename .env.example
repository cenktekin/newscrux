# ========================================
# Newscrux Configuration
# ========================================

# AI provider: openrouter | ollama (default: openrouter)
AI_PROVIDER=openrouter

# OpenRouter API Key (required if provider=openrouter)
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter model (default: deepseek/deepseek-v3.2-speciale)
OPENROUTER_MODEL=deepseek/deepseek-v3.2-speciale

# Ollama configuration (used if provider=ollama)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=deepseek-qwen-8b:latest
OLLAMA_TEMPERATURE=0.2
# false = disable reasoning/thinking output for speed
OLLAMA_THINK=false
# Token caps to reduce latency
OLLAMA_SUMMARY_MAX_TOKENS=260
OLLAMA_RELEVANCE_MAX_TOKENS=1200
# Request timeout and retry for Ollama API calls
OLLAMA_TIMEOUT_MS=45000
OLLAMA_MAX_RETRIES=2

# Pushover credentials (required)
# Get yours at https://pushover.net
PUSHOVER_USER_KEY=your_pushover_user_key_here
PUSHOVER_APP_TOKEN=your_pushover_app_token_here

# RSS poll interval in minutes (default: 15)
POLL_INTERVAL_MINUTES=15

# Maximum articles to process per poll cycle (default: 10)
MAX_ARTICLES_PER_POLL=10

# arXiv papers per poll cycle (default: 15)
ARXIV_MAX_PER_POLL=15

# --- Fast mode / performance tuning ---
# Worker counts for per-stage parallel processing
ENRICH_CONCURRENCY=4
SUMMARIZE_CONCURRENCY=2
SEND_CONCURRENCY=3

# Optional post-operation delays in ms (set 0 for max speed)
SUMMARIZE_DELAY_MS=0
SEND_DELAY_MS=0

# Enrichment tuning
SNIPPET_MIN_LENGTH=300
ENRICHED_CONTENT_MAX_LENGTH=3000
SCRAPING_ENABLED=true
SCRAPING_TIMEOUT_MS=10000
SCRAPING_DOMAIN_DELAY_MS=2000

# AI relevance filter threshold, 1-10 (default: 6)
RELEVANCE_THRESHOLD=6

# Max discovered entries to relevance-score per poll cycle
RELEVANCE_BATCH_SIZE=100

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info
